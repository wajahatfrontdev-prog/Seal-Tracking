generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String     @id @default(uuid())
  name             String
  email            String     @unique
  password         String
  role             String     @default("operator")
  status           String     @default("active")
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  scans            Scan[]
  createdSeals     Seal[]     @relation("SealCreator")
  createdShipments Shipment[] @relation("ShipmentCreator")

  @@map("users")
}

model Seal {
  id        String     @id @default(uuid())
  sealCode  String     @unique
  sealType  String
  status    String     @default("active")
  createdAt DateTime   @default(now())
  createdBy String
  scans     Scan[]
  creator   User       @relation("SealCreator", fields: [createdBy], references: [id])
  shipments Shipment[]

  @@index([sealCode])
  @@index([status])
  @@map("seals")
}

model Shipment {
  id                 String   @id @default(uuid())
  sealId             String
  truckId            String
  productName        String
  productDescription String?
  quantity           Int
  unit               String   @default("bags")
  origin             String
  destination        String
  status             String   @default("pending")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  createdBy          String
  scans              Scan[]
  creator            User     @relation("ShipmentCreator", fields: [createdBy], references: [id])
  seal               Seal     @relation(fields: [sealId], references: [id], onDelete: Cascade)

  @@index([sealId])
  @@index([status])
  @@index([truckId])
  @@map("shipments")
}

model Scan {
  id         String    @id @default(uuid())
  sealId     String
  shipmentId String?
  scannedBy  String
  scannedAt  DateTime  @default(now())
  location   String?
  deviceInfo String?
  ipAddress  String?
  user       User      @relation(fields: [scannedBy], references: [id])
  seal       Seal      @relation(fields: [sealId], references: [id], onDelete: Cascade)
  shipment   Shipment? @relation(fields: [shipmentId], references: [id])

  @@index([sealId])
  @@index([scannedAt])
  @@map("scans")
}
